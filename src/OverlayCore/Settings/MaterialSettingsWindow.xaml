<Window x:Class="OpenDash.OverlayCore.Settings.MaterialSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings"
        MinWidth="680" MinHeight="480"
        Width="760" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignBackground}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MaterialStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- NavListBoxItemStyle defined here (not in external file) so that
                 BasedOn can resolve MaterialDesignListBoxItem from
                 Application.Current.Resources via EnsureInitialized(). -->
            <!-- BasedOn must remain StaticResource (DynamicResource not supported).
                 MaterialDesignNavigationListBoxItem is the correct named key in MDIX 5.x
                 for a nav-rail item; it includes Ripple + selection highlight. -->
            <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem"
                   BasedOn="{StaticResource MaterialDesignNavigationListBoxItem}">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Margin" Value="4,2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: navigation panel — MD2 ColorZone provides PrimaryMid surface -->
        <materialDesign:ColorZone Grid.Column="0" Mode="PrimaryMid"
                                  VerticalAlignment="Stretch">
            <DockPanel VerticalAlignment="Stretch" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="Settings"
                           Margin="16,16,16,10"
                           Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"/>
                <ListBox x:Name="CategoryListBox"
                         Style="{StaticResource NavListBoxStyle}"
                         ItemContainerStyle="{StaticResource NavListBoxItemStyle}"
                         Margin="4,0,4,16"
                         SelectionChanged="CategoryListBox_SelectionChanged"/>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Right: content + buttons -->
        <Grid Grid.Column="1" Background="{DynamicResource MaterialDesignPaper}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Category content area -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="ContentScrollViewer_PreviewMouseWheel">
                <ContentControl x:Name="CategoryContent" Margin="24,20,24,8"/>
            </ScrollViewer>

            <!-- OK / Apply / Cancel -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="OkButton"
                            Content="OK" Width="80" Margin="0,0,8,0"
                            Click="OkButton_Click"
                            Style="{DynamicResource MaterialDesignRaisedButton}"/>
                    <Button x:Name="ApplyButton"
                            Content="Apply" Width="80" Margin="0,0,8,0"
                            Click="ApplyButton_Click"
                            Style="{DynamicResource MaterialDesignRaisedButton}"/>
                    <Button x:Name="CancelButton"
                            Content="Cancel" Width="80"
                            Click="CancelButton_Click"
                            Style="{DynamicResource MaterialDesignFlatButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
