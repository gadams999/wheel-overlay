<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors for OpenDash Overlays -->
    <!-- These named brushes are referenced explicitly (SetResourceReference / DynamicResource). -->
    <!-- Implicit control styles are intentionally absent: MaterialDesign2.Defaults.xaml owns those. -->
    <SolidColorBrush x:Key="ThemeBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThemeForeground" Color="#000000" />
    <SolidColorBrush x:Key="ThemeControlBackground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ThemeControlBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="ThemeControlForeground" Color="#000000" />
    <SolidColorBrush x:Key="ThemeSubtext" Color="#666666" />
    <SolidColorBrush x:Key="ThemeAccent" Color="#0078D4" />
    <Color x:Key="ThemeDropShadow">#40000000</Color>

</ResourceDictionary>
