<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors for OpenDash Overlays -->
    <!-- These named brushes are referenced explicitly (SetResourceReference / DynamicResource). -->
    <!-- Implicit control styles are intentionally absent: MaterialDesign2.Defaults.xaml owns those. -->
    <SolidColorBrush x:Key="ThemeBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ThemeForeground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ThemeControlBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="ThemeControlBorder" Color="#555555" />
    <SolidColorBrush x:Key="ThemeControlForeground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ThemeSubtext" Color="#B0B0B0" />
    <SolidColorBrush x:Key="ThemeAccent" Color="#4CC2FF" />
    <Color x:Key="ThemeDropShadow">#40000000</Color>

</ResourceDictionary>
