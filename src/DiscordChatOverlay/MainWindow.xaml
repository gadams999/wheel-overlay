<Window x:Class="OpenDash.DiscordChatOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OpenDash.DiscordChatOverlay.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Declared here (not only in App.xaml) so StaticResource lookup inside
             the DataTemplate is guaranteed to find them regardless of when
             MaterialDesignBootstrap modifies Application.Resources.MergedDictionaries. -->
        <conv:AvatarUrlConverter     x:Key="AvatarUrlConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag handle — only visible when Settings window is open -->
        <Border x:Name="DragHandleBorder"
                Grid.Row="0"
                Background="#CC1A1A2E"
                CornerRadius="4,4,0,0"
                Padding="8,5,8,5"
                Cursor="SizeAll"
                Visibility="Collapsed"
                MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✥"
                           Foreground="#AAAACC"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="Drag to reposition overlay"
                           Foreground="#AAAACC"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Connection indicator (hidden when null) -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ConnectionIndicator}"
                   Foreground="#FFCC00"
                   FontSize="12"
                   Margin="8,4,8,2"
                   TextOptions.TextFormattingMode="Display">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConnectionIndicator}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Speaker list -->
        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding ActiveSpeakers}"
                      Margin="4,0,4,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Outer row — opacity drives the fade animation -->
                    <Grid Opacity="{Binding Opacity}" Margin="2,2,2,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar image (Hidden not Collapsed to preserve column width per FR-014b-layout) -->
                        <!-- Clip to circle to match Discord's rendering style; CDN delivers square images -->
                        <Image Grid.Column="0"
                               Width="28" Height="28"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip>
                                <EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/>
                            </Image.Clip>
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource AvatarUrlConverter}">
                                    <Binding Path="GuildId"/>
                                    <Binding Path="UserId"/>
                                    <Binding Path="GuildAvatarHash"/>
                                    <Binding Path="AvatarHash"/>
                                </MultiBinding>
                            </Image.Source>
                            <Image.Visibility>
                                <Binding Path="AvatarVisible" Converter="{StaticResource BoolToVisibilityConverter}"/>
                            </Image.Visibility>
                        </Image>

                        <!-- Display name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="6,0,4,0"
                                   TextOptions.TextFormattingMode="Display"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- +N more overflow label -->
        <TextBlock Grid.Row="3"
                   Foreground="#AAAAAA"
                   FontSize="12"
                   Margin="8,2,8,4"
                   TextOptions.TextFormattingMode="Display">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding OverflowCount}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
            <Run Text="+"/>
            <Run Text="{Binding OverflowCount, Mode=OneWay}"/>
            <Run Text=" more"/>
        </TextBlock>
    </Grid>
</Window>
