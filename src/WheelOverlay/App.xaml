<Application x:Class="OpenDash.WheelOverlay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="clr-namespace:OpenDash.WheelOverlay.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/OverlayCore;component/Resources/Fonts/SharedFontResources.xaml"/>
                <ResourceDictionary Source="Resources/LightTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <cv:IsSelectedConverter x:Key="IsSelectedConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
