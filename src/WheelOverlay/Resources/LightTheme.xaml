<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors for WheelOverlay v0.6.0 -->
    <SolidColorBrush x:Key="ThemeBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThemeForeground" Color="#000000" />
    <SolidColorBrush x:Key="ThemeControlBackground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ThemeControlBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="ThemeControlForeground" Color="#000000" />
    <SolidColorBrush x:Key="ThemeSubtext" Color="#666666" />
    <SolidColorBrush x:Key="ThemeAccent" Color="#0078D4" />
    <Color x:Key="ThemeDropShadow">#40000000</Color>

    <!-- Implicit control styles so all controls follow the theme -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource ThemeControlBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeControlForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlBorder}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ThemeControlForeground}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource ThemeControlBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeControlForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlBorder}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource ThemeControlBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeControlForeground}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlBorder}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ThemeControlBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeControlForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeControlBorder}" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}" />
    </Style>

</ResourceDictionary>
